# Copy to .env.local and fill values. Never commit real secrets.
OPENROUTER_API_KEY=your_openrouter_key_here
DEV_LOCK_PIN=2025
DEV_KEY=change_this_dev_mode_key

# Optional: server-to-server protection for /api/chat.
# Browser code does not receive this secret.
# If set, only requests with x-internal-app-token can call /api/chat directly.
APP_SECRET=
